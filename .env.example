# Public, frontend-only variables. Safe to commit (with empty values).
# Real values are injected automatically by Lovable Cloud — DO NOT commit a populated .env.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# The following are SERVER-ONLY secrets. They must NEVER appear in this file,
# in the repository, or in the frontend bundle. Configure them in:
#   - Lovable Cloud → Secrets (Edge Function runtime)
# Examples (do NOT uncomment with values):
# OPENAI_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# MICROSOFT_ONEDRIVE_API_KEY=
# LOVABLE_API_KEY=
